{
  "version": "first_batch_classroom_components_v1",
  "architecture": "shared_music_media_foundation_with_independent_components",
  "deliveryOrder": ["song_audio_workbench", "score_audio_sync_player", "ear_training_engine", "vocal_choir_training", "ensemble_conductor"],
  "defaults": {
    "audience": "primary_school",
    "gradePresets": ["lower_primary", "middle_primary", "upper_primary"],
    "solfegeSystem": "movable_do",
    "recordingPolicy": "local_session_only",
    "networkMode": "single_device_classroom",
    "randomQuestionPolicy": "teacher_opt_in_only"
  },
  "components": [
    { "id": "song_audio_workbench", "contract": "song_audio_workbench_v1", "teacherBoundary": ["rights", "phrase_boundary", "classroom_key"] },
    { "id": "score_audio_sync_player", "contract": "score_audio_sync_player_v1", "teacherBoundary": ["score_version", "lyrics_alignment", "reading_quality"] },
    { "id": "ear_training_engine", "contract": "ear_training_engine_v1", "teacherBoundary": ["sight_singing", "sing_back", "musical_expression"] },
    { "id": "vocal_choir_training", "contract": "vocal_choir_training_v1", "teacherBoundary": ["timbre", "breath", "diction", "blend", "expression"] },
    { "id": "ensemble_conductor", "contract": "ensemble_conductor_v1", "teacherBoundary": ["intonation", "balance", "cooperation", "expression"] }
  ]
}

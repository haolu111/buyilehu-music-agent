{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lyrics-rhythm-activity.v2",
  "title": "Lyrics Rhythm Activity V2",
  "type": "object",
  "required": ["version", "gradePreset", "phrases"],
  "properties": {
    "version": { "const": "lyrics_rhythm_activity_v2" },
    "gradePreset": { "enum": ["lower_primary", "middle_primary", "upper_primary"] },
    "practiceMode": { "enum": ["echo", "play_along"], "default": "echo" },
    "phrases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "lyrics", "meter", "bpm", "patternIds", "lyricUnits", "source", "teacherConfirmed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "lyrics": { "type": "string", "minLength": 1 },
          "meter": { "type": "string", "pattern": "^[234]/4$" },
          "bpm": { "type": "number", "minimum": 40, "maximum": 180 },
          "patternIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "lyricUnits": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "text", "targetHitIds"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "text": { "type": "string" },
                "targetHitIds": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            }
          },
          "audioClip": {
            "type": "object",
            "required": ["url", "startSeconds", "endSeconds"],
            "properties": {
              "url": { "type": "string", "minLength": 1 },
              "startSeconds": { "type": "number", "minimum": 0 },
              "endSeconds": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": false
          },
          "source": { "enum": ["musicxml", "midi", "teacher_manual", "recognized_draft"] },
          "teacherConfirmed": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
